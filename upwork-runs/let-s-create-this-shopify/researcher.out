## 7. Backend Blueprint Spec — Complete

File to create: `../mw-backend/art_store_blueprint.py`

```python
"""
Art Print Storefront — Flask Blueprint
Mounts under /art-store on the mw-backend server.

Backs the Art Print Storefront demo at
https://michaelwegter.com/demos/art-print-storefront/

Endpoints:
  GET  /art-store/prints          public print catalog (12 items, Picsum URLs)
  POST /art-store/login           accepts any email+password, returns signed JWT
  POST /art-store/checkout        Bearer-auth required, returns mock order confirmation

Storage: none — pure in-memory seed data + JWT. Does NOT touch auth, DB, or
any existing blueprint.

CORS: handled globally by server.py. No per-blueprint config needed.
"""

import os
import uuid
import datetime
from pathlib import Path

import jwt as pyjwt
from flask import Blueprint, request, jsonify

# ─── Blueprint setup ──────────────────────────────────────────────────────────

art_store_bp = Blueprint("art_store", __name__, url_prefix="/art-store")

# Reuse the server's persistent secret so tokens survive restarts
_key_file  = Path(__file__).parent / "data" / ".secret_key"
SECRET_KEY = _key_file.read_text().strip() if _key_file.exists() else "dev-secret"

# ─── Seed catalog ────────────────────────────────────────────────────────────

_SIZES = [
    {"label": "8 × 10",  "sku": "8x10",  "multiplier": 1.0},
    {"label": "12 × 16", "sku": "12x16", "multiplier": 1.65},
    {"label": "16 × 20", "sku": "16x20", "multiplier": 2.4},
    {"label": "24 × 30", "sku": "24x30", "multiplier": 3.8},
]

def _prices(base):
    return [
        {"size": s["label"], "sku": s["sku"],
         "price": round(base * s["multiplier"] / 5) * 5}
        for s in _SIZES
    ]

PRINTS = [
    {"id":1,  "slug":"birch-morning",   "title":"Birch Morning",   "artist":"A. Halverson",
     "basePrice":95,  "edition":"limited","editionSize":25,"editionNum":7,
     "imgUrl":"https://picsum.photos/seed/birch/800/1000",
     "thumbUrl":"https://picsum.photos/seed/birch/450/560"},
    {"id":2,  "slug":"granite-veil",    "title":"Granite Veil",    "artist":"M. Solis",
     "basePrice":110, "edition":"open",  "editionSize":None,"editionNum":None,
     "imgUrl":"https://picsum.photos/seed/granite/800/1000",
     "thumbUrl":"https://picsum.photos/seed/granite/450/560"},
    {"id":3,  "slug":"river-fog",       "title":"River Fog",       "artist":"A. Halverson",
     "basePrice":85,  "edition":"limited","editionSize":25,"editionNum":3,
     "imgUrl":"https://picsum.photos/seed/river/800/1000",
     "thumbUrl":"https://picsum.photos/seed/river/450/560"},
    {"id":4,  "slug":"amber-dusk",      "title":"Amber Dusk",      "artist":"C. Renaud",
     "basePrice":120, "edition":"open",  "editionSize":None,"editionNum":None,
     "imgUrl":"https://picsum.photos/seed/amber/800/1000",
     "thumbUrl":"https://picsum.photos/seed/amber/450/560"},
    {"id":5,  "slug":"silver-basin",    "title":"Silver Basin",    "artist":"M. Solis",
     "basePrice":95,  "edition":"limited","editionSize":20,"editionNum":12,
     "imgUrl":"https://picsum.photos/seed/basin/800/1000",
     "thumbUrl":"https://picsum.photos/seed/basin/450/560"},
    {"id":6,  "slug":"cobalt-ridge",    "title":"Cobalt Ridge",    "artist":"C. Renaud",
     "basePrice":130, "edition":"open",  "editionSize":None,"editionNum":None,
     "imgUrl":"https://picsum.photos/seed/cobalt/800/1000",
     "thumbUrl":"https://picsum.photos/seed/cobalt/450/560"},
    {"id":7,  "slug":"umber-coast",     "title":"Umber Coast",     "artist":"A. Halverson",
     "basePrice":105, "edition":"limited","editionSize":15,"editionNum":2,
     "imgUrl":"https://picsum.photos/seed/umber/800/1000",
     "thumbUrl":"https://picsum.photos/seed/umber/450/560"},
    {"id":8,  "slug":"jade-hollow",     "title":"Jade Hollow",     "artist":"M. Solis",
     "basePrice":90,  "edition":"open",  "editionSize":None,"editionNum":None,
     "imgUrl":"https://picsum.photos/seed/jade/800/1000",
     "thumbUrl":"https://picsum.photos/seed/jade/450/560"},
    {"id":9,  "slug":"slate-meridian",  "title":"Slate Meridian",  "artist":"C. Renaud",
     "basePrice":115, "edition":"limited","editionSize":25,"editionNum":19,
     "imgUrl":"https://picsum.photos/seed/slate/800/1000",
     "thumbUrl":"https://picsum.photos/seed/slate/450/560"},
    {"id":10, "slug":"opal-field",      "title":"Opal Field",      "artist":"A. Halverson",
     "basePrice":100, "edition":"open",  "editionSize":None,"editionNum":None,
     "imgUrl":"https://picsum.photos/seed/opal/800/1000",
     "thumbUrl":"https://picsum.photos/seed/opal/450/560"},
    {"id":11, "slug":"indigo-shore",    "title":"Indigo Shore",    "artist":"M. Solis",
     "basePrice":125, "edition":"limited","editionSize":10,"editionNum":5,
     "imgUrl":"https://picsum.photos/seed/indigo/800/1000",
     "thumbUrl":"https://picsum.photos/seed/indigo/450/560"},
    {"id":12, "slug":"tidal-ember",     "title":"Tidal Ember",     "artist":"C. Renaud",
     "basePrice":95,  "edition":"open",  "editionSize":None,"editionNum":None,
     "imgUrl":"https://picsum.photos/seed/tidal/800/1000",
     "thumbUrl":"https://picsum.photos/seed/tidal/450/560"},
]

# Attach computed size prices to each print at module load time
for _p in PRINTS:
    _p["sizes"] = _prices(_p["basePrice"])

# ─── Routes ──────────────────────────────────────────────────────────────────

@art_store_bp.route("/prints", methods=["GET"])
def get_prints():
    return jsonify({"prints": PRINTS})


@art_store_bp.route("/login", methods=["POST"])
def login():
    data  = request.get_json(silent=True) or {}
    email = (data.get("email") or "guest@example.com").strip()
    # Any credentials accepted — this is a demo store
    token = pyjwt.encode(
        {"sub": email, "exp": datetime.datetime.utcnow() + datetime.timedelta(hours=1)},
        SECRET_KEY,
        algorithm="HS256",
    )
    return jsonify({"token": token, "email": email})


@art_store_bp.route("/checkout", methods=["POST"])
def checkout():
    # Verify Bearer token
    auth = request.headers.get("Authorization", "")
    raw  = auth.replace("Bearer ", "").strip()
    if not raw:
        return jsonify({"error": "Authentication required"}), 401
    try:
        payload = pyjwt.decode(raw, SECRET_KEY, algorithms=["HS256"])
        email   = payload.get("sub", "guest")
    except pyjwt.PyJWTError:
        return jsonify({"error": "Invalid or expired token"}), 401

    data  = request.get_json(silent=True) or {}
    items = data.get("items", [])
    total = data.get("total", 0)

    order_id = "MW-" + str(uuid.uuid4())[:8].upper()
    return jsonify({
        "orderId":           order_id,
        "status":            "confirmed",
        "email":             email,
        "items":             items,
        "total":             total,
        "estimatedShipping": "3-5 business days",
        "message":           f"Order {order_id} confirmed. A receipt will be sent to {email}.",
    })
```

