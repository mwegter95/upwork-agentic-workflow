## 2. Shopify OS 2.0 Section Schema — Exact Liquid/JSON Patterns

### 2a. Minimal working section file structure

```liquid
<!-- sections/horizontal-gallery.liquid -->

<section class="hs-section" id="section-{{ section.id }}">
  <div class="hs-track" id="hsTrack-{{ section.id }}">
    {% for block in section.blocks %}
      {% case block.type %}
        {% when 'print' %}
          <article class="hs-card" {{ block.shopify_attributes }}>
            {% if block.settings.image %}
              {{ block.settings.image | image_url: width: 800 | image_tag: loading: 'lazy', alt: block.settings.title }}
            {% endif %}
            <div class="hs-card__body">
              <h3>{{ block.settings.title }}</h3>
              <p class="hs-card__price">from ${{ block.settings.base_price }}</p>
            </div>
          </article>
      {% endcase %}
    {% endfor %}
  </div>
  <button class="hs-arrow hs-arrow--prev" aria-label="Previous">&#8592;</button>
  <button class="hs-arrow hs-arrow--next" aria-label="Next">&#8594;</button>
</section>

{% schema %}
{
  "name": "Horizontal Gallery",
  "tag": "section",
  "class": "horizontal-gallery-section",
  "max_blocks": 20,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "Fine Art Prints"
    }
  ],
  "blocks": [
    {
      "type": "print",
      "name": "Print",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Print image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Print title"
        },
        {
          "type": "text",
          "id": "base_price",
          "label": "Base price (8x10)",
          "default": "95"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Horizontal Gallery",
      "category": "Gallery"
    }
  ]
}
{% endschema %}
```

### 2b. CSS horizontal scroll pattern (from confirmed Shopify community pattern)

```css
/* The proven OS 2.0 horizontal scroll pattern */
.hs-track {
  display: grid;
  grid-auto-flow: column;
  grid-auto-columns: var(--hs-card-w, 320px);
  gap: var(--hs-gap, 24px);
  overflow-x: auto;
  scroll-snap-type: x mandatory;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none; /* Firefox */
}
.hs-track::-webkit-scrollbar { display: none; }

.hs-card {
  scroll-snap-align: start;
  width: var(--hs-card-w, 320px);
  flex-shrink: 0;
}
```

### 2c. JS drag + arrow pattern (confirmed working pattern)

```js
// Drag-to-scroll
let isDown = false, startX, scrollLeft;
track.addEventListener('mousedown', e => {
  isDown = true; track.classList.add('dragging');
  startX = e.pageX - track.offsetLeft;
  scrollLeft = track.scrollLeft;
});
track.addEventListener('mouseleave', () => { isDown = false; });
track.addEventListener('mouseup',    () => { isDown = false; });
track.addEventListener('mousemove',  e => {
  if (!isDown) return;
  e.preventDefault();
  const x = e.pageX - track.offsetLeft;
  track.scrollLeft = scrollLeft - (x - startX) * 1.5;
});

// Arrow navigation
const cardWidth = track.querySelector('.hs-card').offsetWidth + 24; // gap
prevBtn.addEventListener('click', () => track.scrollBy({ left: -cardWidth, behavior: 'smooth' }));
nextBtn.addEventListener('click', () => track.scrollBy({ left:  cardWidth, behavior: 'smooth' }));

// Wheel remapping (vertical -> horizontal)
track.addEventListener('wheel', e => {
  e.preventDefault();
  track.scrollBy({ left: e.deltaY * 2, behavior: 'auto' });
}, { passive: false });
```

### 2d. Metafield Liquid syntax for edition numbering

```liquid
<!-- In product.liquid — reading edition metafields -->
{% if product.metafields.print.edition_type == 'limited' %}
  <p class="edition-badge">
    Edition {{ product.metafields.print.edition_number }}
    of {{ product.metafields.print.edition_size }}
  </p>
{% else %}
  <p class="edition-badge">Open Edition</p>
{% endif %}

<!-- Print details metafield -->
<div class="print-details">
  {% if product.metafields.print.medium %}
    <span>Medium: {{ product.metafields.print.medium }}</span>
  {% endif %}
  {% if product.metafields.print.substrate %}
    <span>Printed on: {{ product.metafields.print.substrate }}</span>
  {% endif %}
</div>
```

Metafield namespace for this project: `print`
Keys: `edition_type` (text), `edition_number` (number_integer), `edition_size` (number_integer), `medium` (text), `substrate` (text).

