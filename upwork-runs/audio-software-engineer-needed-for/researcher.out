## 8. Waveform Canvas

```js
// Draw static waveform on AudioBuffer load (downsample to canvas width)
function drawWaveform(canvas, audioBuffer) {
  const ctx = canvas.getContext('2d');
  const data = audioBuffer.getChannelData(0);  // use first stem (pads or drums)
  const step = Math.floor(data.length / canvas.width);
  const amp = canvas.height / 2;
  ctx.strokeStyle = '#4A9EFF';
  ctx.lineWidth = 1;
  ctx.beginPath();
  for (let x = 0; x < canvas.width; x++) {
    const sample = data[x * step];
    const y = amp + sample * amp * 0.8;
    x === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
  }
  ctx.stroke();
  // Section markers: draw colored vertical lines at section.startSec / totalDuration * canvasWidth
}

// Playhead: rAF loop, draw line at (audioCtx.currentTime - playStartTime + pauseOffset) / totalDuration * width
// Click-to-seek: canvas.addEventListener('click', e => seek(e.offsetX / canvas.width * song.totalDuration))
```

