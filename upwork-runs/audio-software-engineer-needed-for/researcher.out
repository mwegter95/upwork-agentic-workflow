## 4. Audio Synthesis Params (per stem — CEO requirement: MUST sound musical)

All stems generated with `OfflineAudioContext` for each song at runtime (on first load). 8-bar loop buffers. Rendered in-memory, no files.

### Root frequencies by key
```js
const ROOT_HZ = { A: 110, G: 98 };   // A2, G2
const INTERVALS = {  // multipliers from root
  M3: 1.2599, P5: 1.4983, M7: 1.8877, oct: 2.0
};
// Song 1 A: root=110, M3=138.6, P5=164.8, oct=220
// Song 2 G: root=98,  M3=123.4, P5=146.8, oct=196
```

### DRUMS (generate as sequenced events in OfflineAudioContext)

```js
// Pattern per bar: kick beats 1+3, snare beats 2+4, closed-hat all 8ths
function schedKick(offCtx, t, accent=1.0) {
  const osc = offCtx.createOscillator();
  const gain = offCtx.createGain();
  osc.type = 'sine';
  osc.frequency.setValueAtTime(180, t);
  osc.frequency.exponentialRampToValueAtTime(40, t + 0.28);
  gain.gain.setValueAtTime(accent * 0.85, t);
  gain.gain.exponentialRampToValueAtTime(0.001, t + 0.30);
  osc.connect(gain); gain.connect(offCtx.destination);
  osc.start(t); osc.stop(t + 0.32);
}

function schedSnare(offCtx, t) {
  const buf = generateNoiseBuffer(offCtx, 0.18);
  const src = offCtx.createBufferSource();
  src.buffer = buf;
  const bpf = offCtx.createBiquadFilter();
  bpf.type = 'bandpass'; bpf.frequency.value = 1500; bpf.Q.value = 1.8;
  const gain = offCtx.createGain();
  gain.gain.setValueAtTime(0.55, t);
  gain.gain.exponentialRampToValueAtTime(0.001, t + 0.16);
  src.connect(bpf); bpf.connect(gain); gain.connect(offCtx.destination);
  src.start(t); src.stop(t + 0.18);
}

function schedHihat(offCtx, t, open=false) {
  const buf = generateNoiseBuffer(offCtx, open ? 0.32 : 0.05);
  const src = offCtx.createBufferSource();
  src.buffer = buf;
  const hpf = offCtx.createBiquadFilter();
  hpf.type = 'highpass'; hpf.frequency.value = open ? 7000 : 9000;
  const gain = offCtx.createGain();
  const decayEnd = open ? 0.28 : 0.04;
  gain.gain.setValueAtTime(open ? 0.18 : 0.22, t);
  gain.gain.exponentialRampToValueAtTime(0.001, t + decayEnd);
  src.connect(hpf); hpf.connect(gain); gain.connect(offCtx.destination);
  src.start(t); src.stop(t + decayEnd + 0.01);
}

function generateNoiseBuffer(offCtx, dur) {
  const frames = Math.ceil(offCtx.sampleRate * dur);
  const buf = offCtx.createBuffer(1, frames, offCtx.sampleRate);
  const data = buf.getChannelData(0);
  for (let i = 0; i < frames; i++) data[i] = Math.random() * 2 - 1;
  return buf;
}
// Loop: for each bar, schedule kick+snare+hats per beat pattern
// Beat-1 kick accent: accent=1.0; beat-3: accent=0.8
```

### BASS (2 oscillators, melodic root-5th pattern)

```js
function schedBassNote(offCtx, t, freq, dur) {
  const osc1 = offCtx.createOscillator(); // sine (warmth)
  const osc2 = offCtx.createOscillator(); // triangle (body)
  osc1.type = 'sine';    osc1.frequency.value = freq;
  osc2.type = 'triangle'; osc2.frequency.value = freq;
  const g1 = offCtx.createGain(); g1.gain.value = 1.0;
  const g2 = offCtx.createGain(); g2.gain.value = 0.30;
  const env = offCtx.createGain();
  env.gain.setValueAtTime(0, t);
  env.gain.linearRampToValueAtTime(0.72, t + 0.01);   // fast attack
  env.gain.setValueAtTime(0.72, t + 0.08);
  env.gain.linearRampToValueAtTime(0.55, t + 0.12);   // decay to sustain
  env.gain.setValueAtTime(0.55, t + dur - 0.12);
  env.gain.linearRampToValueAtTime(0, t + dur);        // release
  osc1.connect(g1); osc2.connect(g2);
  g1.connect(env); g2.connect(env); env.connect(offCtx.destination);
  osc1.start(t); osc2.start(t); osc1.stop(t+dur); osc2.stop(t+dur);
}
// Pattern per bar (4/4, quarter notes):
// Song 1 A: [root(110), root(110), P5(164.8), root(110)]  durations: [beatDur*0.9 each]
// Song 2 G: [root(98),  root(98),  P5(146.8), root(98) ]
```

### KEYS (3 oscillators per chord, piano-like)

```js
// Chord hits on beats 1 and 3 of each bar, short decay
function schedKeys(offCtx, t, rootFreq) {
  const freqs = [rootFreq*2, rootFreq*2*1.2599, rootFreq*2*1.4983]; // root8va, M3, P5
  const gains = [1.0, 0.55, 0.42];
  const lpf = offCtx.createBiquadFilter();
  lpf.type = 'lowpass'; lpf.frequency.value = 3800; lpf.Q.value = 0.7;
  const env = offCtx.createGain();
  env.gain.setValueAtTime(0, t);
  env.gain.linearRampToValueAtTime(0.6, t + 0.015);  // snappy attack
  env.gain.exponentialRampToValueAtTime(0.35, t + 0.25); // decay
  env.gain.setValueAtTime(0.35, t + 0.6);
  env.gain.linearRampToValueAtTime(0, t + 1.1);       // release
  lpf.connect(env); env.connect(offCtx.destination);
  freqs.forEach((f, i) => {
    const osc = offCtx.createOscillator();
    osc.type = 'triangle';
    osc.frequency.value = f;
    const g = offCtx.createGain(); g.gain.value = gains[i];
    osc.connect(g); g.connect(lpf);
    osc.start(t); osc.stop(t + 1.2);
  });
}
```

### PADS (4 detuned sawtooths, rich and lush — MOST IMPORTANT for worship feel)

```js
function renderPads(offCtx, song) {
  const dur = song.loopDuration;
  const rootFreq = ROOT_HZ[song.synthKey];
  // Chord voicings: root, M3, P5, octave — one oscillator each
  const chordFreqs = [
    rootFreq,
    rootFreq * 1.2599,
    rootFreq * 1.4983,
    rootFreq * 2.0,
  ];
  const detuneCents = [-14, -4, +4, +14];  // warm chorus spread

  const lpf = offCtx.createBiquadFilter();
  lpf.type = 'lowpass'; lpf.frequency.value = 900; lpf.Q.value = 0.5;

  // Tremolo LFO (breathing effect)
  const lfo = offCtx.createOscillator();
  const lfoGain = offCtx.createGain();
  lfo.frequency.value = 0.15; lfoGain.gain.value = 0.04;
  lfo.connect(lfoGain);

  const env = offCtx.createGain();
  env.gain.setValueAtTime(0, 0);
  env.gain.linearRampToValueAtTime(0.55, 1.2);    // slow attack 1.2s
  env.gain.setValueAtTime(0.55, dur - 2.5);
  env.gain.linearRampToValueAtTime(0, dur);        // slow release 2.5s
  lfoGain.connect(env.gain);  // tremolo modulates gain
  lpf.connect(env); env.connect(offCtx.destination);

  chordFreqs.forEach((f, i) => {
    const osc = offCtx.createOscillator();
    osc.type = 'sawtooth';
    osc.frequency.value = f;
    osc.detune.value = detuneCents[i];
    const g = offCtx.createGain(); g.gain.value = 0.25;
    osc.connect(g); g.connect(lpf);
    osc.start(0); osc.stop(dur);
  });
  lfo.start(0); lfo.stop(dur);
}
```

### CLICK (sharp transient, beat-1 accent)

```js
function schedClick(offCtx, t, isAccent) {
  const osc = offCtx.createOscillator();
  const env = offCtx.createGain();
  osc.type = 'sine';
  osc.frequency.value = isAccent ? 1300 : 900;
  env.gain.setValueAtTime(isAccent ? 0.85 : 0.45, t);
  env.gain.exponentialRampToValueAtTime(0.001, t + (isAccent ? 0.020 : 0.014));
  osc.connect(env); env.connect(offCtx.destination);
  osc.start(t); osc.stop(t + 0.025);
}
// Schedule for every beat; isAccent = (beat % 4 === 0)
```

### GUIDE (filtered sawtooth, voice-like, subtle)

```js
// Plays a root-M3-P5-root melodic motif per bar, vibrato
function schedGuideNote(offCtx, t, freq, dur) {
  const osc = offCtx.createOscillator();
  osc.type = 'sawtooth';
  osc.frequency.value = freq * 4;  // 2 octaves up from bass root = melody register

  // Vibrato
  const vibLfo = offCtx.createOscillator();
  const vibGain = offCtx.createGain();
  vibLfo.frequency.value = 5.5;
  vibGain.gain.value = freq * 4 * 0.006;  // ~6 cents depth
  vibLfo.connect(vibGain); vibGain.connect(osc.frequency);

  // Bandpass filter (nasal, vocal-like)
  const bpf = offCtx.createBiquadFilter();
  bpf.type = 'bandpass'; bpf.frequency.value = 700; bpf.Q.value = 8;

  const env = offCtx.createGain();
  env.gain.setValueAtTime(0, t);
  env.gain.linearRampToValueAtTime(0.38, t + 0.04);
  env.gain.setValueAtTime(0.38, t + dur - 0.25);
  env.gain.linearRampToValueAtTime(0, t + dur);

  osc.connect(bpf); bpf.connect(env); env.connect(offCtx.destination);
  vibLfo.start(t); osc.start(t); osc.stop(t+dur); vibLfo.stop(t+dur);
}
// Motif per bar (quarter notes): root4, M3*4, P5*4, root4
// root*4 = 4x bass root (two octaves up): A2(110) -> A4(440) for Song1
// Guide overall mix gain: 0.38 (subtle reference, not dominant)
```

