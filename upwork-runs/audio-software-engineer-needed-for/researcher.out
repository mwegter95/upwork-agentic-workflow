## 6. Mixer Solo Logic

```js
// "Radio solo": only one channel can be solo-ed; OR multiple if additive preferred
// When any stem is soloed, all non-soloed stems → muteGain.gain = 0
function applySolo(stems, soloedId) {
  const anySoloed = soloedId !== null;
  stems.forEach(s => {
    const shouldMute = anySoloed && s.id !== soloedId;
    s.muteGain.gain.linearRampToValueAtTime(shouldMute ? 0 : 1, audioCtx.currentTime + 0.01);
  });
}
// Mute button: s.muteGain.gain = s.muted ? 0 : 1 (independent of solo)
// Volume slider: s.volumeGain.gain = value / 100
// Pan knob: s.pannerNode.pan.value = panValue (-1 to +1)
```

---

## 7. Count-In Implementation

```js
// Before play: schedule N bars of click-only (all other stems muted at engine level)
// Visual overlay: animated beat counter 4→3→2→1→GO on downbeats
function startWithCountIn(bars, bpm, onComplete) {
  const beatDur = 60 / bpm;
  const countBeats = bars * 4;
  let beat = 0;

  for (let i = 0; i < countBeats; i++) {
    const t = audioCtx.currentTime + i * beatDur + 0.05;
    schedClick(audioCtx, t, i % 4 === 0);  // accent on beat 1
    // Visual flash: use setTimeout matching audio time
    const delay = (t - audioCtx.currentTime) * 1000;
    setTimeout(() => updateCountDisplay(countBeats - i), delay);
  }
  setTimeout(() => {
    startPlayback();
    onComplete();
  }, (countBeats * beatDur + 0.1) * 1000);
}
// Count-in note: all non-click stems remain muted/unstarted during count-in
// audioCtx IS running during count-in (not suspended)
```

