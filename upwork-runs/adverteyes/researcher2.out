const CAMPAIGN_COLORS = ['#FF6B1A','#3B82F6','#22C55E','#EAB308','#A78BFA','#EC4899','#14B8A6'];
const campaignColor = (id: number) => CAMPAIGN_COLORS[id % CAMPAIGN_COLORS.length];
