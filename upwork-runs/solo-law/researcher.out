## 10. Flask Blueprint OOP Skeleton (mw-backend/solo_law_blueprint.py)

Pattern: mirrors `edtech_blueprint.py` (SQLite + bcrypt + JWT) + OOP class wrapping. Reference those files directly.

```python
"""
Solo Law CMS — Flask Blueprint
Mounts under /solo-law on the mw-backend server.
Auth: per-boot JWT secret (demo). Storage: SQLite at data/mw.db (WAL mode).
"""
import sqlite3, datetime, secrets
from pathlib import Path
from functools import wraps
import bcrypt, jwt as _jwt
from flask import Blueprint, request, jsonify

solo_law_bp = Blueprint("solo_law", __name__, url_prefix="/solo-law")

_JWT_SECRET = secrets.token_hex(32)
_JWT_ALG    = "HS256"
_JWT_TTL    = datetime.timedelta(hours=24)

DATA_DIR = Path(__file__).parent / "data"
DB_PATH  = DATA_DIR / "mw.db"

# --- DB class (OOP) ---
class SoloLawDB:
    def __init__(self):
        self.conn = sqlite3.connect(DB_PATH, check_same_thread=False)
        self.conn.row_factory = sqlite3.Row
        self.conn.execute("PRAGMA journal_mode=WAL;")
    def close(self): self.conn.close()

def _db() -> sqlite3.Connection:
    conn = sqlite3.connect(DB_PATH)
    conn.row_factory = sqlite3.Row
    conn.execute("PRAGMA journal_mode=WAL;")
    return conn

# --- Auth helpers ---
def _make_token(email, role):
    return _jwt.encode({"email": email, "role": role,
        "exp": datetime.datetime.utcnow() + _JWT_TTL}, _JWT_SECRET, algorithm=_JWT_ALG)

def require_auth(f):
    @wraps(f)
    def wrapper(*args, **kwargs):
        auth = request.headers.get("Authorization", "")
        if not auth.startswith("Bearer "):
            return jsonify({"error": "Unauthorized"}), 401
        try:
            request.sl_user = _jwt.decode(auth[7:], _JWT_SECRET, algorithms=[_JWT_ALG])
        except _jwt.ExpiredSignatureError:
            return jsonify({"error": "Token expired"}), 401
        except Exception:
            return jsonify({"error": "Invalid token"}), 401
        return f(*args, **kwargs)
    return wrapper

# --- Model classes ---
class PracticeAreaModel:
    @staticmethod
    def get_all(locale="en"):
        with _db() as conn:
            return [dict(r) for r in conn.execute(
                "SELECT * FROM sl_practice_areas WHERE locale=? AND published=1 ORDER BY display_order", (locale,))]
    @staticmethod
    def get_by_slug(slug, locale="en"):
        with _db() as conn:
            return dict(conn.execute(
                "SELECT * FROM sl_practice_areas WHERE slug=? AND locale=?", (slug, locale)).fetchone() or {})
    # create / update / delete follow same pattern

class PublicationModel:
    @staticmethod
    def get_all(locale="en", practice_area_id=None, page=1, per_page=10):
        with _db() as conn:
            q = "SELECT * FROM sl_publications WHERE locale=? AND published=1"
            params = [locale]
            if practice_area_id:
                q += " AND practice_area_id=?"; params.append(practice_area_id)
            q += " ORDER BY published_at DESC LIMIT ? OFFSET ?"
            params += [per_page, (page-1)*per_page]
            return [dict(r) for r in conn.execute(q, params)]

class SeedManager:
    @staticmethod
    def seed():
        """Idempotent seed — runs on first startup if tables empty."""
        # (demo-builder inserts full seed data from section 8+9 above)
        pass

# --- Init ---
def _init_schema():
    with _db() as conn:
        conn.executescript("""
            CREATE TABLE IF NOT EXISTS sl_practice_areas (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                slug TEXT NOT NULL, locale TEXT NOT NULL,
                title TEXT, tagline TEXT, body_html TEXT,
                icon_emoji TEXT, hero_image_url TEXT,
                display_order INTEGER DEFAULT 0,
                published INTEGER DEFAULT 1,
                updated_at TEXT
            );
            CREATE UNIQUE INDEX IF NOT EXISTS ux_sl_pa ON sl_practice_areas(slug, locale);

            CREATE TABLE IF NOT EXISTS sl_publications (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                slug TEXT NOT NULL, locale TEXT NOT NULL,
                title TEXT, excerpt TEXT, body_html TEXT,
                author TEXT, practice_area_id INTEGER,
                published_at TEXT, published INTEGER DEFAULT 1, updated_at TEXT
            );
            CREATE UNIQUE INDEX IF NOT EXISTS ux_sl_pub ON sl_publications(slug, locale);

            CREATE TABLE IF NOT EXISTS sl_brand_assets (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                name TEXT, type TEXT, value TEXT, tag TEXT, created_at TEXT
            );

            CREATE TABLE IF NOT EXISTS sl_cms_users (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                email TEXT UNIQUE NOT NULL,
                password_hash TEXT NOT NULL,
                role TEXT DEFAULT 'editor',
                created_at TEXT
            );
        """)

_init_schema()
SeedManager.seed()
```

