### MoneyDisplay component pattern
```tsx
// Always IBM Plex Mono, tabular-nums — NEVER render raw minorUnits
export function MoneyDisplay({ minorUnits, currency = 'USD', size = 'md' }: MoneyDisplayProps) {
  const formatted = formatMoney(minorUnits, currency);
  return (
    <span
      style={{
        fontFamily: 'var(--font-mono)',
        fontVariantNumeric: 'tabular-nums',
        fontSize: size === 'lg' ? '1.5rem' : size === 'sm' ? '0.85rem' : '1rem',
        color: minorUnits < 0 ? 'var(--status-rejected)' : 'var(--text-primary)',
      }}
    >
      {formatted}
    </span>
  );
}
```

