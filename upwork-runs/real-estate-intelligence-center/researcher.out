## 2. WebLLM Init Pattern (main thread, no separate worker file)

The 12-file cap does NOT include a worker file. Use `CreateMLCEngine` on the main thread — inference is async and non-blocking at the JS level for await callers; the UI updates via status callbacks. Do NOT add a 13th worker file.

```js
// llm-router.js — exact init pattern
const PRIMARY_MODEL  = "Qwen2.5-7B-Instruct-q4f16_1-MLC";
const ROUTER_MODEL   = "Qwen2.5-1.5B-Instruct-q4f16_1-MLC";
const FALLBACK_MODEL = "Qwen2.5-3B-Instruct-q4f16_1-MLC";

let primaryEngine = null;
let routerEngine  = null;
let mockMode      = false;
let activeModel   = null;

async function detectVRAM(adapter) {
  // WebGPU has no direct VRAM query API; proxy via adapterInfo.description
  const info = await adapter.requestAdapterInfo();
  const desc = (info.description || "").toLowerCase();
  // Conservative: if integrated GPU signal found, use fallback
  const isIntegrated = desc.includes("intel") || desc.includes("integrated") || desc.includes("apple m");
  return isIntegrated ? "low" : "high";
}

export async function initLLMRouter(onProgress) {
  if (!navigator.gpu) { mockMode = true; onProgress(1, "Mock mode — no WebGPU", "mock"); return; }

  try {
    const adapter = await navigator.gpu.requestAdapter();
    if (!adapter) { mockMode = true; onProgress(1, "Mock mode — no adapter", "mock"); return; }

    const { CreateMLCEngine } = await import("https://cdn.jsdelivr.net/npm/@mlc-ai/web-llm@0.2.84/+esm");
    const vram = await detectVRAM(adapter);
    const chosenPrimary = vram === "low" ? FALLBACK_MODEL : PRIMARY_MODEL;
    if (vram === "low") onProgress(0.01, "Compact model selected for your GPU", "info");

    activeModel = chosenPrimary;
    primaryEngine = await CreateMLCEngine(chosenPrimary, {
      initProgressCallback: (p) => onProgress(p.progress, p.text || "Loading model...", "loading")
    });

    // Load router model in background (non-blocking)
    CreateMLCEngine(ROUTER_MODEL, {}).then(e => { routerEngine = e; }).catch(() => {});

    onProgress(1, `${chosenPrimary} ready`, "ready");
  } catch (err) {
    console.warn("WebLLM init failed, mock mode:", err);
    mockMode = true;
    onProgress(1, "Mock mode active", "mock");
  }
}

export async function runLLM(engineName, systemPrompt, userPrompt, schema) {
  if (mockMode) return cannedResponse(engineName);

  const engine = routerEngine || primaryEngine;
  const t0 = Date.now();
  const resp = await primaryEngine.chat.completions.create({
    messages: [
      { role: "system", content: systemPrompt },
      { role: "user", content: userPrompt }
    ],
    response_format: { type: "json_object" },
    temperature: 0.7,
    max_tokens: 1200
  });

  const raw = resp.choices[0].message.content;
  let parsed;
  try { parsed = JSON.parse(raw); }
  catch {
    // 1-retry reflection
    const retry = await primaryEngine.chat.completions.create({
      messages: [
        { role: "system", content: systemPrompt },
        { role: "user", content: userPrompt },
        { role: "assistant", content: raw },
        { role: "user", content: `Your output was not valid JSON. Rewrite it as valid JSON matching this schema: ${JSON.stringify(schema)}` }
      ],
      response_format: { type: "json_object" },
      max_tokens: 1200
    });
    parsed = JSON.parse(retry.choices[0].message.content);
  }

  const tokenEst = Math.round((raw.length / 4));
  return {
    output: parsed,
    model: activeModel,
    cost_usd: tokenEst * 0.000002,
    duration_ms: Date.now() - t0
  };
}

export function isMockMode() { return mockMode; }
export function getActiveModel() { return activeModel || "mock"; }
```

