## IndexedDB Schema

```js
// Database: "pathwaize-ic", version: 1
stores: {
  runs: {
    id: string (uuid),
    engine: "authority" | "newsletter" | "knowledge",
    input: string,
    model: string,
    output_id: string,
    cost_usd: number,
    duration_ms: number,
    timestamp: ISOString,
    workspace_id: string
  },
  outputs: {
    id: string,
    run_id: string,
    engine: string,
    content: Object,           // raw engine output JSON
    status: StatusEnum,
    revision_notes: string | null,
    destination: "gdrive" | "github" | "linkedin" | "twitter" | null,
    created_at: ISOString,
    approved_at: ISOString | null,
    pushed_at: ISOString | null
  },
  logs: {
    id: string,
    run_id: string,
    event: "run_start" | "run_complete" | "approved" | "push_attempt" | "error",
    detail: Object,
    timestamp: ISOString
  },
  workspace: {
    id: string,
    name: string,
    business_context: string,
    niche: string,
    location: string,
    tone: string
  }
}
```

