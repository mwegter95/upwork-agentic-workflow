## 5. ET hours check (escalation.js)

```js
function getETStatus() {
  const now = new Date();
  // ET offset: EST = -5, EDT = -4. Use Intl to get exact ET hour.
  const etHour = parseInt(new Intl.DateTimeFormat("en-US", {
    timeZone: "America/New_York", hour: "numeric", hour12: false
  }).format(now));
  const etDay = parseInt(new Intl.DateTimeFormat("en-US", {
    timeZone: "America/New_York", weekday: "short"
  }).format(now).slice(0,3) === "Sun" ? 0 : ["Sun","Mon","Tue","Wed","Thu","Fri","Sat"].indexOf(
    new Intl.DateTimeFormat("en-US", { timeZone: "America/New_York", weekday: "short" }).format(now)
  ));
  const isWeekday = etDay >= 1 && etDay <= 5;
  const isBusinessHours = etHour >= 9 && etHour < 18;
  if (isWeekday && isBusinessHours) {
    return { available: true, msg: "Our support team is online now and will respond within a few minutes." };
  } else {
    // Next open = next Mon at 9am ET (if weekend) or next weekday 9am ET
    return { available: false, msg: "Our team is offline right now (available Mon-Fri, 9am-6pm ET). Leave a message and we'll reply first thing when we're back." };
  }
}
```

