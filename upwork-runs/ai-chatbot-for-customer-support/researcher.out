### model-loader.js — top of file
```js
// Tier 1: WebLLM (WebGPU only)
// import { CreateMLCEngine } from "https://cdn.jsdelivr.net/npm/@mlc-ai/web-llm@0.2.84/+esm";
// Model: "Llama-3.2-1B-Instruct-q4f16_1-MLC"
// ~879 MB VRAM, ~600-900 MB one-time IndexedDB download

// Tier 2: Transformers.js WASM (Playwright CI path — must be fully functional)
import { pipeline } from "https://cdn.jsdelivr.net/npm/@huggingface/transformers@4.2.0/+esm";
// DO NOT use @xenova/transformers — frozen/EOL
// Instruction model:
//   pipeline("text-generation", "onnx-community/Qwen2.5-0.5B-Instruct", { dtype: "q4", device: "wasm" })
// Embedding model (for RAG cosine sim):
//   pipeline("feature-extraction", "Xenova/all-MiniLM-L6-v2", { dtype: "fp32", device: "wasm" })
```

### Tier detection pattern
```js
async function detectTier() {
  if (navigator.gpu) {
    try {
      const adapter = await navigator.gpu.requestAdapter();
      if (adapter) return "webgpu";
    } catch {}
  }
  return "wasm"; // Playwright headless = always wasm
}
```

### Tier 1 init (WebGPU)
```js
import { CreateMLCEngine } from "https://cdn.jsdelivr.net/npm/@mlc-ai/web-llm@0.2.84/+esm";
const engine = await CreateMLCEngine("Llama-3.2-1B-Instruct-q4f16_1-MLC", {
  initProgressCallback: (p) => updateProgress(p.progress, p.text)
});
// generate:
const reply = await engine.chat.completions.create({
  messages: [{ role: "system", content: systemPrompt }, { role: "user", content: userMsg }],
  stream: true
});
for await (const chunk of reply) {
  const token = chunk.choices[0]?.delta?.content || "";
  appendToken(token); // stream into chat bubble
}
```

### Tier 2 init (WASM — primary tested path)
```js
import { pipeline } from "https://cdn.jsdelivr.net/npm/@huggingface/transformers@4.2.0/+esm";
let chatPipe, embedPipe;
async function initWasm(onProgress) {
  chatPipe = await pipeline("text-generation", "onnx-community/Qwen2.5-0.5B-Instruct",
    { dtype: "q4", device: "wasm", progress_callback: onProgress });
  embedPipe = await pipeline("feature-extraction", "Xenova/all-MiniLM-L6-v2",
    { dtype: "fp32", device: "wasm" });
}
// generate (WASM — no streaming, ~3-8s, show typing indicator the whole time):
async function generateWasm(systemPrompt, userMsg) {
  const messages = [{ role: "system", content: systemPrompt }, { role: "user", content: userMsg }];
  const out = await chatPipe(messages, { max_new_tokens: 256, do_sample: false });
  // Extract generated text:
  return out[0].generated_text.at(-1).content;
}
// embed:
async function embedWasm(text) {
  const out = await embedPipe(text, { pooling: "mean", normalize: true });
  return Array.from(out.data); // Float32 vector
}
```

### Tier 3 — template-RAG fallback (no LLM at all)
Return top-1 retrieved FAQ answer verbatim. If confidence < 0.3, trigger escalation suggestion.

