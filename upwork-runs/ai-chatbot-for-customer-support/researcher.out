## 3. RAG implementation pattern

```js
// rag.js
// At init: embed all knowledge-base.json answers with embedPipe, store Float32 arrays
// At query time: embed userQuery, cosine sim against all stored vectors, take top-3

function cosine(a, b) {
  let dot = 0, na = 0, nb = 0;
  for (let i = 0; i < a.length; i++) { dot += a[i]*b[i]; na += a[i]*a[i]; nb += b[i]*b[i]; }
  return dot / (Math.sqrt(na) * Math.sqrt(nb));
}

// Returns: [{ entry, score }] sorted desc, top-3
async function retrieve(queryText, topK = 3) {
  const qVec = await embedWasm(queryText);
  return corpusVecs
    .map((vec, i) => ({ entry: corpus[i], score: cosine(qVec, vec) }))
    .sort((a,b) => b.score - a.score)
    .slice(0, topK);
}

// System prompt injection:
function buildSystemPrompt(topChunks) {
  const context = topChunks.map(c => `Q: ${c.entry.q}\nA: ${c.entry.a}`).join("\n\n");
  return `You are SupportAI, a helpful US customer support assistant for an online retail store.
Answer ONLY using the context below. If the answer is not in the context, say you're not sure and offer to connect a human agent.
Be friendly, concise, and in a US retail customer service tone.

CONTEXT:
${context}`;
}
```

**Keyword fallback** (when embedPipe not yet loaded): tokenize query, count word matches against FAQ question text, score = matched_words / total_words. Use as interim until WASM embeddings load.

