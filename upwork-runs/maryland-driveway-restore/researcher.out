## 12. GA4 Event Hooks (include in main.js and header.php)

```javascript
// GA4 snippet: G-PLACEHOLDER (client provides real ID post-launch)
window.dataLayer = window.dataLayer || [];
function gtag(){dataLayer.push(arguments);}
gtag('js', new Date());
gtag('config', 'G-PLACEHOLDER');

// Track key events
document.querySelectorAll('.cta-call').forEach(el => el.addEventListener('click', () => gtag('event', 'cta_click_call', {event_category: 'CTA'})));
document.querySelectorAll('.cta-text').forEach(el => el.addEventListener('click', () => gtag('event', 'cta_click_text', {event_category: 'CTA'})));
document.querySelector('.estimate-form')?.addEventListener('submit', () => gtag('event', 'form_submit', {event_category: 'Lead'}));
document.querySelectorAll('.gallery-thumb').forEach(el => el.addEventListener('click', () => gtag('event', 'gallery_view', {event_category: 'Engagement'})));
document.querySelector('[data-section="pricing"]')?.addEventListener('mouseenter', () => gtag('event', 'pricing_view', {event_category: 'Engagement'}), {once: true});
```

