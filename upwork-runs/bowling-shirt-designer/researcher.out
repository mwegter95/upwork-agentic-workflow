## 9. Procedural shirt mesh snippet (ShirtCanvas.tsx key parts)

```tsx
'use client';
import { useRef, useMemo } from 'react';
import { Canvas } from '@react-three/fiber';
import { OrbitControls, Decal } from '@react-three/drei';
import * as THREE from 'three';
import { useStore } from '@/lib/store';
import { buildPatterns } from '@/lib/patterns';

// Call buildPatterns() once outside the component at module level.
// Guard with typeof window !== 'undefined' for SSR safety.
let _patterns: ReturnType<typeof buildPatterns> | null = null;
function getPatterns() {
  if (typeof window === 'undefined') return null;
  if (!_patterns) _patterns = buildPatterns();
  return _patterns;
}

function ShirtMesh() {
  const { bodyColor, collarColor, cuffColor, pattern, uploadedUrl,
          backText, textColor, fontSize, fontFamily } = useStore();
  const patterns = getPatterns();

  // Uploaded texture
  const uploadedTexture = useMemo(() => {
    if (!uploadedUrl) return null;
    const t = new THREE.TextureLoader().load(uploadedUrl);
    t.wrapS = t.wrapT = THREE.RepeatWrapping;
    t.repeat.set(3, 3);
    return t;
  }, [uploadedUrl]);

  // Active body map
  const bodyMap = uploadedUrl
    ? uploadedTexture
    : (patterns && pattern !== 'none' ? patterns[pattern as keyof typeof patterns] : null);

  // Text-on-back CanvasTexture (debounced upstream)
  const textTexture = useMemo(() => {
    if (!backText) return null;
    const c = document.createElement('canvas');
    c.width = 512; c.height = 256;
    const ctx = c.getContext('2d')!;
    ctx.clearRect(0, 0, 512, 256);
    ctx.font = `bold ${fontSize}px ${fontFamily}`;
    ctx.fillStyle = textColor;
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';
    ctx.fillText(backText, 256, 128);
    const t = new THREE.CanvasTexture(c);
    t.needsUpdate = true;
    return t;
  }, [backText, textColor, fontSize, fontFamily]);

  return (
    <group>
      {/* Body */}
      <mesh position={[0, 0, 0]}>
        <boxGeometry args={[1.0, 1.3, 0.2]} />
        <meshStandardMaterial color={bodyColor} map={bodyMap ?? undefined} />
      </mesh>
      {/* Collar */}
      <mesh position={[0, 0.72, 0]} rotation={[Math.PI / 2, 0, 0]}>
        <torusGeometry args={[0.22, 0.06, 8, 24]} />
        <meshStandardMaterial color={collarColor} />
      </mesh>
      {/* Left sleeve */}
      <mesh position={[-0.68, 0.3, 0]} rotation={[0, 0, Math.PI / 3]}>
        <cylinderGeometry args={[0.13, 0.16, 0.45, 12]} />
        <meshStandardMaterial color={cuffColor} />
      </mesh>
      {/* Right sleeve */}
      <mesh position={[0.68, 0.3, 0]} rotation={[0, 0, -Math.PI / 3]}>
        <cylinderGeometry args={[0.13, 0.16, 0.45, 12]} />
        <meshStandardMaterial color={cuffColor} />
      </mesh>
      {/* Back text decal on back face */}
      {backText && textTexture && (
        <Decal
          position={[0, 0.1, -0.101]}
          rotation={[0, Math.PI, 0]}
          scale={[0.55, 0.28, 1]}
          map={textTexture}
        />
      )}
    </group>
  );
}

// Canvas wrapper (used from ShirtCustomizer with next/dynamic ssr:false)
export default function ShirtCanvas() {
  return (
    <Canvas camera={{ position: [0, 0, 3], fov: 40 }} style={{ background: '#1a1f3c' }}>
      <ambientLight intensity={0.6} />
      <directionalLight position={[3, 4, 5]} intensity={1.2} />
      <ShirtMesh />
      <OrbitControls enablePan={false} minDistance={1.5} maxDistance={6} autoRotate autoRotateSpeed={1.5} />
    </Canvas>
  );
}
```

