## 7. Zustand store skeleton (lib/store.ts)

```ts
import { create } from 'zustand';

export type PatternKey = 'none' | 'starburst' | 'pins' | 'argyle' | 'polka' | 'chevrons' | 'bowtie';

interface ShirtState {
  // Customizer
  bodyColor:   string;  // '#e84040'
  collarColor: string;  // '#1a1f3c'
  cuffColor:   string;  // '#f5a623'
  pattern:     PatternKey;
  backText:    string;
  textColor:   string;  // '#f5f0e8'
  fontSize:    number;  // 72
  fontFamily:  string;  // 'Impact'
  uploadedUrl: string | null;
  // Product
  size:     string;  // 'M'
  qty:      number;  // 1
  // Cart
  cartItems: CartItem[];
  sessionId: string | null;
  // Actions
  setBodyColor:   (c: string) => void;
  setCollarColor: (c: string) => void;
  setCuffColor:   (c: string) => void;
  setPattern:     (p: PatternKey) => void;
  setBackText:    (t: string) => void;
  setTextColor:   (c: string) => void;
  setFontSize:    (n: number) => void;
  setFontFamily:  (f: string) => void;
  setUploadedUrl: (u: string | null) => void;
  setSize:        (s: string) => void;
  setQty:         (n: number) => void;
  addToCart:      (thumbnail: string) => void;
  removeFromCart: (id: string) => void;
  setSessionId:   (id: string) => void;
}

const PRICE = 89;

export const useStore = create<ShirtState>((set, get) => ({
  bodyColor: '#e84040', collarColor: '#1a1f3c', cuffColor: '#f5a623',
  pattern: 'none', backText: '', textColor: '#f5f0e8', fontSize: 72,
  fontFamily: 'Impact', uploadedUrl: null,
  size: 'M', qty: 1, cartItems: [], sessionId: null,

  setBodyColor:   (c) => set({ bodyColor: c }),
  setCollarColor: (c) => set({ collarColor: c }),
  setCuffColor:   (c) => set({ cuffColor: c }),
  setPattern:     (p) => set({ pattern: p }),
  setBackText:    (t) => set({ backText: t }),
  setTextColor:   (c) => set({ textColor: c }),
  setFontSize:    (n) => set({ fontSize: n }),
  setFontFamily:  (f) => set({ fontFamily: f }),
  setUploadedUrl: (u) => set({ uploadedUrl: u }),
  setSize:        (s) => set({ size: s }),
  setQty:         (n) => set({ qty: n }),

  addToCart: (thumbnail) => set((s) => ({
    cartItems: [...s.cartItems, {
      id: crypto.randomUUID(),
      size: s.size, qty: s.qty,
      bodyColor: s.bodyColor, collarColor: s.collarColor, cuffColor: s.cuffColor,
      pattern: s.pattern, backText: s.backText,
      price: PRICE * s.qty,
      thumbnail,
    }],
  })),
  removeFromCart: (id) => set((s) => ({
    cartItems: s.cartItems.filter((i) => i.id !== id),
  })),
  setSessionId: (id) => set({ sessionId: id }),
}));

export interface CartItem {
  id: string; size: string; qty: number;
  bodyColor: string; collarColor: string; cuffColor: string;
  pattern: PatternKey; backText: string;
  price: number; thumbnail: string;
}
```

