## §NEW-A — compositor.ts (lib/compositor.ts)

Full file — new:

```ts
/**
 * 2048×2048 CanvasTexture compositor.
 *
 * UV island layout (CylinderGeometry, radialSegments 48, seam at U=0/U=1,
 * front centered at U=0.5):
 *   FRONT island: canvas x  512–1536  (U 0.25–0.75, px width 1024)
 *   BACK  island: canvas x  0–512 + 1536–2048 (U 0–0.25 + 0.75–1, split strips)
 *   V maps 0=bottom to 1=top; canvas y 0=top, so y = (1-V)*2048.
 */

import * as THREE from 'three';
import type { ImageTransform } from './store';

const W = 2048;
// Front: x 512..1536, Back: x 0..512 + x 1536..2048
const FRONT_X  = 512;
const FRONT_W  = 1024;
const BACK_L_X = 0;
const BACK_L_W = 512;
const BACK_R_X = 1536;
const BACK_R_W = 512;

let _canvas: HTMLCanvasElement | null = null;
let _ctx: CanvasRenderingContext2D | null = null;
let _texture: THREE.CanvasTexture | null = null;

export function getCompositorTexture(): THREE.CanvasTexture {
  if (!_texture) {
    _canvas = document.createElement('canvas');
    _canvas.width = _canvas.height = W;
    _ctx = _canvas.getContext('2d')!;
    _texture = new THREE.CanvasTexture(_canvas);
    _texture.wrapS = _texture.wrapT = THREE.ClampToEdgeWrapping;
  }
  return _texture;
}

let _rafId: number | null = null;
let _dirty = false;
let _lastParams: CompositeParams | null = null;

export interface CompositeParams {
  baseColor:      string;
  pattern?:       THREE.CanvasTexture | null;
  frontImage:     HTMLImageElement | null;
  backImage:      HTMLImageElement | null;
  frontTransform: ImageTransform;
  backTransform:  ImageTransform;
  uploadMode:     'wrap' | 'frontback';
  mirrorSeam:     boolean;
}

export function scheduleRecompose(params: CompositeParams) {
  _lastParams = params;
  _dirty = true;
  if (_rafId === null) {
    _rafId = requestAnimationFrame(() => {
      _rafId = null;
      if (_dirty && _lastParams) {
        recompose(_lastParams);
        _dirty = false;
      }
    });
  }
}

function applyTransform(
  ctx: CanvasRenderingContext2D,
  img: HTMLImageElement,
  destX: number, destY: number, destW: number, destH: number,
  t: ImageTransform
) {
  ctx.save();
  ctx.beginPath();
  ctx.rect(destX, destY, destW, destH);
  ctx.clip();

  const cx = destX + destW / 2 + t.offsetX * destW;
  const cy = destY + destH / 2 + t.offsetY * destH;
  ctx.translate(cx, cy);
  ctx.rotate((t.rotation * Math.PI) / 180);
  ctx.scale(t.scale, t.scale);

  // Draw image centered at origin, scaled to fill the dest rectangle
  const aspect = img.naturalWidth / img.naturalHeight;
  const destAspect = destW / destH;
  let dw: number, dh: number;
  if (aspect > destAspect) {
    dh = destH; dw = dh * aspect;
  } else {
    dw = destW; dh = dw / aspect;
  }
  ctx.drawImage(img, -dw / 2, -dh / 2, dw, dh);
  ctx.restore();
}

function recompose(p: CompositeParams) {
  if (!_canvas || !_ctx || !_texture) return;
  const ctx = _ctx;

  // 1. Base color fill
  ctx.fillStyle = p.baseColor;
  ctx.fillRect(0, 0, W, W);

  // 2. Pattern layer (tiled, if no image override)
  if (p.pattern && !p.frontImage && !p.backImage) {
    // Draw pattern canvas into the compositing canvas via pattern fill
    const pCanvas = (p.pattern as any).image as HTMLCanvasElement;
    if (pCanvas) {
      const pat = ctx.createPattern(pCanvas, 'repeat');
      if (pat) {
        ctx.fillStyle = pat;
        ctx.fillRect(0, 0, W, W);
      }
    }
  }

  // 3. Image layers
  if (p.uploadMode === 'wrap') {
    // Single image, all the way around: fill entire 2048×2048
    const img = p.frontImage;
    if (img) {
      applyTransform(ctx, img, 0, 0, W, W, p.frontTransform);
      if (p.mirrorSeam) {
        // Draw mirrored at the edges to reduce seam visibility
        ctx.save();
        ctx.translate(W, 0);
        ctx.scale(-1, 1);
        applyTransform(ctx, img, 0, 0, W / 8, W, p.frontTransform);
        ctx.restore();
      }
    }
  } else {
    // Front/back separate
    if (p.frontImage) {
      applyTransform(ctx, p.frontImage, FRONT_X, 0, FRONT_W, W, p.frontTransform);
    }
    const backImg = p.backImage ?? p.frontImage; // if no back, mirror front
    if (backImg) {
      // Left back strip
      applyTransform(ctx, backImg, BACK_L_X, 0, BACK_L_W, W, p.backTransform);
      // Right back strip — mirror-seam flips horizontally so strips join seamlessly
      ctx.save();
      ctx.translate(BACK_R_X + BACK_R_W, 0);
      ctx.scale(-1, 1);
      applyTransform(ctx, backImg, 0, 0, BACK_R_W, W, p.backTransform);
      ctx.restore();
    }
  }

  _texture!.needsUpdate = true;
}
```

