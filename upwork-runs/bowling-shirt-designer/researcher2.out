## §7 UPDATED — Zustand store additions (lib/store.ts)

Add to `ShirtState` interface and `create()` call — surgical edit only:

```ts
// Add to ShirtState interface
  // Image upload
  uploadMode:   'wrap' | 'frontback';   // wrap = one image all around; frontback = separate
  frontImage:   HTMLImageElement | null;
  backImage:    HTMLImageElement | null;
  mirrorSeam:   boolean;
  // Per-image transforms (front and back independent)
  frontTransform: ImageTransform;
  backTransform:  ImageTransform;
  // Actions
  setUploadMode:    (m: 'wrap' | 'frontback') => void;
  setFrontImage:    (img: HTMLImageElement | null) => void;
  setBackImage:     (img: HTMLImageElement | null) => void;
  setMirrorSeam:    (v: boolean) => void;
  setFrontTransform:(t: Partial<ImageTransform>) => void;
  setBackTransform: (t: Partial<ImageTransform>) => void;

// Add new type
export interface ImageTransform {
  scale:    number;   // default 1.0  (zoom)
  offsetX:  number;   // default 0.0  (−1 to 1 in canvas fraction)
  offsetY:  number;   // default 0.0
  rotation: number;   // default 0.0  (degrees)
}

const DEFAULT_TRANSFORM: ImageTransform = { scale: 1, offsetX: 0, offsetY: 0, rotation: 0 };

// In create() defaults:
  uploadMode: 'wrap', frontImage: null, backImage: null, mirrorSeam: false,
  frontTransform: { ...DEFAULT_TRANSFORM }, backTransform: { ...DEFAULT_TRANSFORM },

// Actions:
  setUploadMode:    (m) => set({ uploadMode: m }),
  setFrontImage:    (img) => set({ frontImage: img }),
  setBackImage:     (img) => set({ backImage: img }),
  setMirrorSeam:    (v) => set({ mirrorSeam: v }),
  setFrontTransform:(t) => set((s) => ({ frontTransform: { ...s.frontTransform, ...t } })),
  setBackTransform: (t) => set((s) => ({ backTransform: { ...s.backTransform, ...t } })),
```

Also REMOVE `uploadedUrl: string | null` / `setUploadedUrl` (replaced by `frontImage`/`backImage`).

