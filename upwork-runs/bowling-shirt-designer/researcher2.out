## §NEW-C — ShirtCanvas.tsx key changes

Replace the flat box/primitive mesh with this pattern:

```tsx
'use client';
import { useRef, useMemo, useEffect } from 'react';
import { Canvas, useFrame } from '@react-three/fiber';
import { OrbitControls, Environment, ContactShadows } from '@react-three/drei';
import * as THREE from 'three';
import { useStore } from '@/lib/store';
import { buildPatterns } from '@/lib/patterns';
import { getCompositorTexture, scheduleRecompose } from '@/lib/compositor';

// --- Knit normal map (Poly Haven CC0) ---
// Primary URL (cors-ok for browser fetch — check once at build time):
const KNIT_NORMAL_URL =
  'https://dl.polyhaven.org/file/ph-assets/Textures/jpg/1k/knit_fabric_02/knit_fabric_02_nor_gl_1k.jpg';
// Fallback (vendor into demo-src/public/fabric_nor.jpg at build if CORS fails):
// const KNIT_NORMAL_URL = '/demos/bowling-shirt-designer/fabric_nor.jpg';

// --- Procedural shirt body geometry (LatheGeometry-style via CylinderGeometry + vertex displacement) ---
function makeShirtBody(): THREE.BufferGeometry {
  // CylinderGeometry: openEnded, 48 radial, 8 height segments, radius=0.45
  const geo = new THREE.CylinderGeometry(0.45, 0.45, 1.8, 48, 8, true);
  // Vertex displacement: profile(normalizedY) scale radii for bowlifi silhouette
  const pos = geo.attributes.position;
  for (let i = 0; i < pos.count; i++) {
    const y = pos.getY(i);                        // −0.9 to +0.9
    const yn = y / 0.9;                           // −1 to +1
    const r = profile(yn);
    const x = pos.getX(i), z = pos.getZ(i);
    const len = Math.sqrt(x * x + z * z) || 1;
    pos.setXYZ(i, (x / len) * r, y, (z / len) * r);
  }
  pos.needsUpdate = true;
  geo.computeVertexNormals();
  return geo;
}

// Profile: radial scale as a function of normalized Y (−1=hem, +1=collar base)
function profile(yn: number): number {
  // Bowlifi silhouette: slightly flared hem, nipped waist, full chest, tapers to collar
  if (yn < -0.5) return THREE.MathUtils.lerp(0.48, 0.42, (yn + 1) / 0.5); // hem→waist
  if (yn < 0.1)  return THREE.MathUtils.lerp(0.42, 0.50, (yn + 0.5) / 0.6); // waist→chest
  if (yn < 0.65) return THREE.MathUtils.lerp(0.50, 0.44, (yn - 0.1) / 0.55); // chest→shoulder
  return THREE.MathUtils.lerp(0.44, 0.22, (yn - 0.65) / 0.35); // shoulder→collar
}

// Sleeve geometry: short, angled (bowling jersey = mid-bicep)
function makeSleeveGeo(): THREE.BufferGeometry {
  return new THREE.CylinderGeometry(0.14, 0.17, 0.38, 20, 1);
}

// Mandarin/band collar: thin cylinder band at top of body
function makeCollarGeo(): THREE.BufferGeometry {
  return new THREE.CylinderGeometry(0.225, 0.225, 0.12, 32, 1, true);
}

function ShirtMesh() {
  const state = useStore();
  const compositorTexture = useMemo(() => getCompositorTexture(), []);
  const patterns = useMemo(() => {
    if (typeof window === 'undefined') return null;
    return buildPatterns();
  }, []);
  const normalMap = useMemo(() => {
    const loader = new THREE.TextureLoader();
    const t = loader.load(KNIT_NORMAL_URL);
    t.wrapS = t.wrapT = THREE.RepeatWrapping;
    t.repeat.set(4, 4);
    return t;
  }, []);

  const bodyGeo = useMemo(() => makeShirtBody(), []);
  const sleeveGeo = useMemo(() => makeSleeveGeo(), []);
  const collarGeo = useMemo(() => makeCollarGeo(), []);

  // Drive compositor on every state change that affects the texture
  useEffect(() => {
    scheduleRecompose({
      baseColor:      state.bodyColor,
      pattern:        patterns && state.pattern !== 'none'
                        ? patterns[state.pattern as keyof typeof patterns]
                        : null,
      frontImage:     state.frontImage,
      backImage:      state.backImage,
      frontTransform: state.frontTransform,
      backTransform:  state.backTransform,
      uploadMode:     state.uploadMode,
      mirrorSeam:     state.mirrorSeam,
    });
  }, [
    state.bodyColor, state.pattern,
    state.frontImage, state.backImage,
    state.frontTransform, state.backTransform,
    state.uploadMode, state.mirrorSeam,
    patterns,
  ]);

  const fabricMat = (
    <meshPhysicalMaterial
      map={compositorTexture}
      normalMap={normalMap}
      normalScale={new THREE.Vector2(0.5, 0.5)}
      roughness={0.85}
      metalness={0}
      sheen={0.9}
      sheenColor={new THREE.Color(state.bodyColor)}
      sheenRoughness={0.45}
      side={THREE.DoubleSide}
    />
  );

  const trimMat = (
    <meshPhysicalMaterial
      color={state.collarColor}
      roughness={0.8}
      metalness={0}
      sheen={0.4}
      sheenColor={new THREE.Color(state.collarColor)}
      sheenRoughness={0.6}
    />
  );

  const cuffMat = (
    <meshPhysicalMaterial
      color={state.cuffColor}
      roughness={0.8}
      metalness={0}
    />
  );

  return (
    <group position={[0, 0.1, 0]}>
      {/* Body */}
      <mesh geometry={bodyGeo}>{fabricMat}</mesh>

      {/* Mandarin collar band */}
      <mesh position={[0, 0.97, 0]} geometry={collarGeo}>{trimMat}</mesh>

      {/* Left sleeve: angled ~35° outward-down */}
      <mesh
        geometry={sleeveGeo}
        position={[-0.54, 0.55, 0]}
        rotation={[0, 0, (Math.PI / 180) * 50]}
      >
        {fabricMat}
      </mesh>
      {/* Cuff trim on left sleeve */}
      <mesh position={[-0.76, 0.33, 0]} rotation={[0, 0, (Math.PI / 180) * 50]}>
        <cylinderGeometry args={[0.14, 0.14, 0.06, 20]} />
        {cuffMat}
      </mesh>

      {/* Right sleeve */}
      <mesh
        geometry={sleeveGeo}
        position={[0.54, 0.55, 0]}
        rotation={[0, 0, -(Math.PI / 180) * 50]}
      >
        {fabricMat}
      </mesh>
      <mesh position={[0.76, 0.33, 0]} rotation={[0, 0, -(Math.PI / 180) * 50]}>
        <cylinderGeometry args={[0.14, 0.14, 0.06, 20]} />
        {cuffMat}
      </mesh>

      {/* Shirt bottom cap */}
      <mesh position={[0, -0.9, 0]} rotation={[-Math.PI / 2, 0, 0]}>
        <circleGeometry args={[0.48, 48]} />
        {fabricMat}
      </mesh>
    </group>
  );
}

export default function ShirtCanvas() {
  return (
    <Canvas
      shadows
      camera={{ position: [0, 0.4, 2.8], fov: 38 }}
      style={{ background: '#f0ede8' }}  // neutral off-white studio bg
    >
      <Environment preset="studio" background={false} />
      <directionalLight
        position={[3, 8, 5]}
        intensity={1.2}
        castShadow
        shadow-mapSize={[2048, 2048]}
      />
      <ambientLight intensity={0.4} />
      <ContactShadows
        position={[0, -1.05, 0]}
        opacity={0.4}
        scale={2.5}
        blur={1.5}
        far={1.5}
      />
      <ShirtMesh />
      <OrbitControls
        enablePan={false}
        minDistance={1.8}
        maxDistance={5}
        autoRotate
        autoRotateSpeed={1.2}
        target={[0, 0.1, 0]}
      />
    </Canvas>
  );
}
```

