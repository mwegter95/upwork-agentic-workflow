## §NEW-D — OptionsPanel.tsx additions (partial — surgical edit)

Add these UI blocks to OptionsPanel (INSERT before or after the existing color pickers section):

```tsx
// --- Upload mode toggle ---
<div className="flex gap-2 mb-3">
  <button
    onClick={() => setUploadMode('wrap')}
    className={`flex-1 py-1.5 rounded text-sm font-ui font-semibold
      ${uploadMode === 'wrap' ? 'bg-coral text-white' : 'bg-navy/40 text-cream'}`}
  >All-Around Wrap</button>
  <button
    onClick={() => setUploadMode('frontback')}
    className={`flex-1 py-1.5 rounded text-sm font-ui font-semibold
      ${uploadMode === 'frontback' ? 'bg-coral text-white' : 'bg-navy/40 text-cream'}`}
  >Front / Back</button>
</div>

{/* Front image upload */}
<ImageUploadSlot
  label={uploadMode === 'wrap' ? 'Image (wraps all around)' : 'Front Image'}
  onLoad={(img) => setFrontImage(img)}
  transform={frontTransform}
  onTransform={(t) => setFrontTransform(t)}
  onSmartAlign={async (img) => {
    const box = contentBbox(img);
    setFrontTransform(boxToTransform(box));
    // Lazy WASM refine in background
    imglyRefine(img).then((box2) => setFrontTransform(boxToTransform(box2)));
  }}
/>

{uploadMode === 'frontback' && (
  <ImageUploadSlot
    label="Back Image (optional — uses front if blank)"
    onLoad={(img) => setBackImage(img)}
    transform={backTransform}
    onTransform={(t) => setBackTransform(t)}
    onSmartAlign={async (img) => {
      const box = contentBbox(img);
      setBackTransform(boxToTransform(box));
      imglyRefine(img).then((box2) => setBackTransform(boxToTransform(box2)));
    }}
  />
)}

<label className="flex items-center gap-2 text-sm font-ui text-cream/70 mt-1">
  <input type="checkbox" checked={mirrorSeam}
    onChange={(e) => setMirrorSeam(e.target.checked)} />
  Mirror seam edges (reduces visible seam on non-tiling images)
</label>
```

**`ImageUploadSlot` sub-component (inline in OptionsPanel.tsx):**

```tsx
function ImageUploadSlot({ label, onLoad, transform, onTransform, onSmartAlign }: {
  label: string;
  onLoad: (img: HTMLImageElement) => void;
  transform: ImageTransform;
  onTransform: (t: Partial<ImageTransform>) => void;
  onSmartAlign: (img: HTMLImageElement) => void;
}) {
  const [currentImg, setCurrentImg] = useState<HTMLImageElement | null>(null);
  const [analyzing, setAnalyzing] = useState(false);

  const handleFile = (e: React.ChangeEvent<HTMLInputElement>) => {
    const file = e.target.files?.[0]; if (!file) return;
    const url = URL.createObjectURL(file);
    const img = new Image();
    img.onload = () => { setCurrentImg(img); onLoad(img); };
    img.src = url;
  };

  return (
    <div className="mb-4 p-3 rounded-lg bg-navy/30 border border-cream/10">
      <p className="text-xs font-ui text-cream/60 mb-1">{label}</p>
      <input type="file" accept="image/*" onChange={handleFile}
        className="text-xs text-cream/80 mb-2 w-full" />
      {currentImg && (
        <>
          {/* Smart-align button */}
          <button
            onClick={async () => {
              setAnalyzing(true);
              await onSmartAlign(currentImg);
              setAnalyzing(false);
            }}
            disabled={analyzing}
            className="w-full mb-2 py-1 rounded bg-gold text-navy text-xs font-semibold"
          >
            {analyzing ? '✨ Analyzing…' : '✨ Smart Align'}
          </button>
          {/* Transform sliders */}
          <SliderRow label="Zoom" min={0.3} max={4} step={0.01}
            value={transform.scale} onChange={(v) => onTransform({ scale: v })} />
          <SliderRow label="X Pan" min={-1} max={1} step={0.01}
            value={transform.offsetX} onChange={(v) => onTransform({ offsetX: v })} />
          <SliderRow label="Y Pan" min={-1} max={1} step={0.01}
            value={transform.offsetY} onChange={(v) => onTransform({ offsetY: v })} />
          <SliderRow label="Rotate" min={-180} max={180} step={1}
            value={transform.rotation} onChange={(v) => onTransform({ rotation: v })} />
        </>
      )}
    </div>
  );
}

function SliderRow({ label, min, max, step, value, onChange }: {
  label: string; min: number; max: number; step: number;
  value: number; onChange: (v: number) => void;
}) {
  return (
    <div className="flex items-center gap-2 mb-1">
      <span className="text-xs text-cream/60 w-12 shrink-0">{label}</span>
      <input type="range" min={min} max={max} step={step} value={value}
        onChange={(e) => onChange(parseFloat(e.target.value))}
        className="flex-1 accent-coral" />
      <span className="text-xs text-cream/50 w-8 text-right">{value.toFixed(2)}</span>
    </div>
  );
}
```

