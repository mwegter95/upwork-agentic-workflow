# Dependencies
node_modules/

# Python
__pycache__/
*.pyc
venv/
.venv/

# Env
.env
.env.local

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# Logs
*.log

# Capture / browser artifacts (kept out of git; live demos are the source of truth)
upwork-runs/**/proposal/media/*.webm
upwork-runs/**/.tmp/
.playwright-cache/

# Large downloaded/generated files — exceed GitHub's 100MB limit
# Target download staging dirs specifically; demo source assets are allowed
upwork-runs/**/*-download/
upwork-runs/**/downloads/
# Archive files are never needed in git
*.zip
*.tar.gz
*.tar.bz2
*.7z
