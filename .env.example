# Copy to .env (gitignored). The Surface runner secret — must match mw-backend's
# RUN_SECRET. Treat it like an SSH key; anyone with it can run code on the Surface.
# Generate one: python3 -c "import secrets; print(secrets.token_hex(32))"
RUN_SECRET=

# Where the Surface runner is reachable (the tunneled Flask backend).
RUN_BASE_URL=https://api.michaelwegter.com
